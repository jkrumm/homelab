{
  "distSpecVersion": "1.1.0",
  "storage": {
    "rootDirectory": "/var/lib/registry"
  },
  "http": {
    "address": "0.0.0.0",
    "port": "5080",
    "auth": {
      "htpasswd": {
        "path": "/etc/zot/htpasswd"
      }
    },
    "accessControl": {
      "repositories": {
        "private/**": {
          "anonymousPolicy": [],
          "defaultPolicy": [],
          "policies": [
            {
              "users": ["jkrumm"],
              "actions": ["read", "create", "update", "delete"]
            }
          ]
        },
        "**": {
          "anonymousPolicy": ["read"],
          "defaultPolicy": ["read"],
          "policies": [
            {
              "users": ["jkrumm"],
              "actions": ["read", "create", "update", "delete"]
            }
          ]
        }
      },
      "adminPolicy": {
        "users": ["jkrumm"],
        "actions": ["read", "create", "update", "delete", "createRepository"]
      }
    }
  },
  "log": {
    "level": "info"
  },
  "extensions": {
    "ui": { "enable": true },
    "search": {
      "enable": true,
      "cve": {
        "updateInterval": "24h"
      }
    },
    "trust": {
      "enable": true,
      "cosign": true
    }
  }
}
