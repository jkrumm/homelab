{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-var": "error",
    "eqeqeq": "error",
    "no-console": "warn",
    "no-shadow": "off",
    "react/rules-of-hooks": "error",
    "react/jsx-key": "error",
    "react/react-in-jsx-scope": "off",
    "typescript/no-explicit-any": "warn",
    "import/no-duplicates": "error",
    "import/no-unassigned-import": "off"
  },
  "ignorePatterns": ["packages/api/src/generated/**", "packages/dashboard/dist/**"],
  "overrides": [
    {
      "files": [
        "packages/dashboard/src/charts/**",
        "packages/dashboard/src/pages/**/visx-charts.tsx",
        "packages/dashboard/src/pages/**/charts.tsx"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@visx/tooltip",
                "message": "Use ChartTooltip + TooltipHeader/Row/Body from src/charts/primitives instead — they are theme-aware."
              }
            ]
          }
        ]
      }
    }
  ]
}
