{
  "name": "homelab",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt 'packages/**' '!**/generated/**' '!**/dist/**' --write",
    "format:check": "oxfmt 'packages/**' '!**/generated/**' '!**/dist/**' --check"
  },
  "devDependencies": {
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0"
  }
}
