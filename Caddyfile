{
	acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	auto_https disable_redirects
}

# === PUBLIC SERVICES (Cloudflare + Tailscale) ===
# Both http:// (cloudflared) and https:// (Tailscale) variants

glance.jkrumm.com, http://glance.jkrumm.com {
	reverse_proxy glance:8080
}

immich.jkrumm.com, http://immich.jkrumm.com {
	reverse_proxy immich-server:2283
}

uptime.jkrumm.com, http://uptime.jkrumm.com {
	reverse_proxy uptime-kuma:3001
}

public.jkrumm.com, http://public.jkrumm.com {
	reverse_proxy dufs:5000
}

images.jkrumm.com, http://images.jkrumm.com {
	reverse_proxy image-share:7720
}

# Friendly public share links — bare `/<slug>` maps to the app's `/s/<slug>`
# surface. /health is passed through unrewritten for the container healthcheck
# and Uptime Kuma monitor.
share.jkrumm.com, http://share.jkrumm.com {
	handle /health {
		reverse_proxy image-share:7720
	}
	# Share-page asset URLs (img/file/zip/unlock) are already /s/-prefixed in
	# the rendered HTML — pass them through untouched so they don't become /s/s/*.
	handle /s/* {
		reverse_proxy image-share:7720
	}
	handle {
		rewrite * /s{uri}
		reverse_proxy image-share:7720
	}
}

# === PRIVATE SERVICES (Tailscale only, HTTPS enforced) ===
# HTTP requests are permanently redirected to HTTPS

beszel.jkrumm.com {
	reverse_proxy beszel:8090
}
http://beszel.jkrumm.com {
	redir https://{host}{uri} permanent
}

dozzle.jkrumm.com {
	reverse_proxy dozzle:8081
}
http://dozzle.jkrumm.com {
	redir https://{host}{uri} permanent
}

files.jkrumm.com {
	reverse_proxy filebrowser:80
}
http://files.jkrumm.com {
	redir https://{host}{uri} permanent
}

# CouchDB (private, Tailscale only — Obsidian LiveSync)
couchdb.jkrumm.com {
	reverse_proxy couchdb:5984
}
http://couchdb.jkrumm.com {
	redir https://{host}{uri} permanent
}

# Garmin Collector (private, Tailscale only — stateless HTTP query layer
# over Garmin Connect for the argo API on VPS). Bearer-authed at the app level.
garmin.jkrumm.com {
	reverse_proxy garmin-collector:8080
}
http://garmin.jkrumm.com {
	redir https://{host}{uri} permanent
}

# Karakeep (private, Tailscale only — read-later / bookmark everything-bucket)
karakeep.jkrumm.com {
	reverse_proxy karakeep:3000
}
http://karakeep.jkrumm.com {
	redir https://{host}{uri} permanent
}


